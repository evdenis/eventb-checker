#!/usr/bin/env bash
set -euo pipefail

# Pre-commit hook: auto-format staged Kotlin files with Spotless

# Find staged .kt/.kts files (Added, Copied, Modified)
staged_files=$(git diff --cached --name-only --diff-filter=ACM | grep -E '\.(kt|kts)$' || true)

if [ -z "$staged_files" ]; then
    exit 0
fi

echo "Pre-commit: formatting staged Kotlin files..."

# Auto-format
./gradlew spotlessApply --quiet

# Re-stage only files that were originally staged AND modified by the formatter
for file in $staged_files; do
    if [ -f "$file" ] && ! git diff --quiet -- "$file" 2>/dev/null; then
        git add "$file"
    fi
done

# Safety net: verify formatting passes
./gradlew spotlessCheck --quiet
